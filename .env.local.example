# MongoDB Atlas — same connection string as your backend
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/flexfit?retryWrites=true&w=majority

# JWT secret — must match your backend JWT_SECRET exactly
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# How long a portal session lasts after OTP verification (e.g. 2h, 1d)
PORTAL_JWT_EXPIRY=2h
